<?php
/**
 * GCash Simulator (Mock Payment - DEMONSTRATION ONLY)
 * POST /api/simulate-payment.php
 * 
 * ⚠️ IMPORTANT: This is a SIMULATION for demonstration purposes only.
 * NO real payment processing occurs. NO actual money will be deducted.
 * The system does NOT integrate with real payment gateways.
 * 
 * This simulator generates mock reference numbers and receipt numbers
 * to demonstrate the affiliation workflow. Actual financial transactions
 * are handled outside the scope of this system.
 * 
 * SOURCE: Deliverable 3.2 - Simulate Payment API (Mock)
 */

session_start();
error_reporting(E_ALL);
ini_set('display_errors', 0);
ini_set('log_errors', 1);

header('Content-Type: application/json');

// Prevent any output before JSON
ob_start();

try {
    // Load config and dependencies
    require_once __DIR__ . '/../../includes/config.php';
    require_once __DIR__ . '/../../src/lib/SupabaseClient.php';

    // Load helpers if exists
    if (file_exists(__DIR__ . '/../../includes/helpers.php')) {
        require_once __DIR__ . '/../../includes/helpers.php';
    }

    // Get Supabase client (use global if available)
    if (isset($GLOBALS['supabaseClient'])) {
        $supabase = $GLOBALS['supabaseClient'];
    } else {
        $config = require __DIR__ . '/../../includes/supabase.php';
        $supabase = new SupabaseClient($config['url'], $config['anon_key']);
    }
} catch (Exception $e) {
    ob_end_clean();
    error_log('Supabase client initialization error: ' . $e->getMessage());
    http_response_code(500);
    echo json_encode(['success' => false, 'error' => 'Database connection error']);
    exit;
}

// Only allow POST
if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
    ob_end_clean();
    http_response_code(405);
    echo json_encode(['success' => false, 'error' => 'Method not allowed']);
    exit;
}

try {
    error_log('Payment simulation started - Method: ' . $_SERVER['REQUEST_METHOD']);
    
    // 1. Parse JSON input
    $rawInput = file_get_contents('php://input');
    error_log('Payment simulation - Raw input length: ' . strlen($rawInput));
    
    $input = json_decode($rawInput, true);
    
    if (json_last_error() !== JSON_ERROR_NONE) {
        ob_end_clean();
        error_log('Payment simulation - JSON decode error: ' . json_last_error_msg());
        http_response_code(400);
        echo json_encode(['success' => false, 'error' => 'Invalid JSON input: ' . json_last_error_msg()]);
        exit;
    }
    
    error_log('Payment simulation - Input decoded successfully');
    
    // 2. Validate CSRF token (skip if function doesn't exist)
    if (function_exists('csrf_field_value')) {
        error_log('Payment simulation - Validating CSRF token');
        if (!isset($input['csrf_token']) || !hash_equals(csrf_field_value(), $input['csrf_token'])) {
            ob_end_clean();
            error_log('Payment simulation - CSRF validation failed');
            http_response_code(403);
            echo json_encode(['success' => false, 'error' => 'Invalid CSRF token']);
            exit;
        }
        error_log('Payment simulation - CSRF token valid');
    } else {
        error_log('Payment simulation - CSRF validation skipped (function not available)');
    }

    // 3. Get fee data from input (frontend calculates and sends)
    error_log('Payment simulation - Extracting fee data from input');
    $totalFee = floatval($input['total_fee'] ?? 0);
    $affiliationFee = floatval($input['affiliation_fee'] ?? 0);
    $operationalFee = floatval($input['operational_fee'] ?? 800);
    $membershipTotal = floatval($input['membership_total'] ?? 0);
    $memberCount = intval($input['member_count'] ?? 0);
    $newMembers = intval($input['new_members'] ?? 0);
    $oldMembers = intval($input['old_members'] ?? 0);
    
    error_log('Payment simulation - Fee data: totalFee=' . $totalFee . ', memberCount=' . $memberCount);
    
    // Validate required fields
    if ($totalFee <= 0 || $memberCount <= 0) {
        ob_end_clean();
        error_log('Payment simulation - Validation failed: totalFee=' . $totalFee . ', memberCount=' . $memberCount);
        http_response_code(400);
        echo json_encode([
            'success' => false, 
            'error' => 'Invalid fee data',
            'debug' => [
                'totalFee' => $totalFee,
                'memberCount' => $memberCount,
                'received_input' => $input
            ]
        ]);
        exit;
    }
    
    error_log('Payment simulation - Fee data validated successfully');
    
    // Store fee calculation in session for later verification
    $_SESSION['affiliation_fee_calc'] = [
        'timestamp' => time(),
        'member_count' => $memberCount,
        'new_members' => $newMembers,
        'old_members' => $oldMembers,
        'affiliation_fee' => $affiliationFee,
        'operational_fee' => $operationalFee,
        'membership_fees_total' => $membershipTotal,
        'total_fee' => $totalFee
    ];

    // 4. Check rate limit: max 3 simulation attempts per session
    if (!isset($_SESSION['payment_simulation_attempts'])) {
        $_SESSION['payment_simulation_attempts'] = 0;
    }

    $_SESSION['payment_simulation_attempts']++;

    if ($_SESSION['payment_simulation_attempts'] > 3) {
        ob_end_clean();
        http_response_code(429);
        echo json_encode(['success' => false, 'error' => 'rate_limit_exceeded']);
        exit;
    }

    // 5. Generate server-side reference and receipt numbers
    $paymentReference = 'GCASH-' . date('Ymd') . '-' . str_pad(random_int(0, 99999), 5, '0', STR_PAD_LEFT);
    $receiptNumber = 'RCP-' . date('Y') . '-' . str_pad(random_int(0, 99999), 5, '0', STR_PAD_LEFT);
    $simulationToken = bin2hex(random_bytes(32));

    // 6. Use the fee data we just stored
    $feeCalc = $_SESSION['affiliation_fee_calc'];
    
    // Try to insert transaction record (optional - continue even if it fails)
    $transactionId = null;
    try {
        $transactionData = [
            'payment_method' => 'gcash_simulated',
            'payment_reference' => $paymentReference,
            'receipt_number' => $receiptNumber,
            'amount' => $feeCalc['total_fee'],
            'transaction_type' => 'affiliation_fee',
            'status' => 'pending',
            'created_at' => date('c')
        ];
        
        $transactionResult = $supabase->insert('transactions', $transactionData);

        if ($transactionResult && is_array($transactionResult)) {
            $transactionId = isset($transactionResult[0]['id']) 
                ? $transactionResult[0]['id'] 
                : (isset($transactionResult['id']) ? $transactionResult['id'] : null);
        }
    } catch (Exception $dbError) {
        // Log but don't fail - transaction record is optional for simulation
        error_log('Transaction insert failed (non-critical): ' . $dbError->getMessage());
    }

    // 7. Store in session
    $_SESSION['affiliation_payment'] = [
        'timestamp' => time(),
        'payment_reference' => $paymentReference,
        'receipt_number' => $receiptNumber,
        'transaction_id' => $transactionId,
        'simulation_token' => $simulationToken,
        'total_fee' => $feeCalc['total_fee'],
        'member_count' => $feeCalc['member_count'],
        'affiliation_fee' => $feeCalc['affiliation_fee'],
        'operational_fee' => $feeCalc['operational_fee'],
        'membership_fees_total' => $feeCalc['membership_fees_total']
    ];

    // 8. Log to audit_logs (if function exists)
    if (function_exists('audit_log')) {
        audit_log(
            null,
            'payment_simulated',
            'affiliation_payment',
            null,
            null,
            ['payment_reference' => $paymentReference, 'total_fee' => $feeCalc['total_fee']]
        );
    }

    // 9. Return response with clear simulation disclaimer
    ob_end_clean();
    error_log('Payment simulation - Success! Receipt: ' . $receiptNumber);
    echo json_encode([
        'success' => true,
        'payment_reference' => $paymentReference,
        'receipt_number' => $receiptNumber,
        'total_fee' => round($feeCalc['total_fee'], 2),
        'message' => '⚠️ SIMULATION ONLY — No real money was charged. This is a demonstration of the payment workflow.'
    ]);

} catch (Exception $e) {
    ob_end_clean();
    error_log('Payment simulation error: ' . $e->getMessage());
    error_log('Payment simulation stack trace: ' . $e->getTraceAsString());
    http_response_code(500);
    
    $isDevelopment = (defined('APP_ENV') && APP_ENV === 'development') || 
                     (getenv('APP_ENV') === 'development');
    
    echo json_encode([
        'success' => false, 
        'error' => 'Server error during payment simulation',
        'details' => $isDevelopment ? $e->getMessage() : null
    ]);
}
